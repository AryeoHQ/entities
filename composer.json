{
    "name": "aryeo/entities",
    "type": "library",
    "repositories": {
        "tooling-laravel": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/tooling-laravel"
        },
        "eloquent-filters": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/eloquent-filters"
        }
    },
    "require": {
        "aryeo/eloquent-filters": "0.0.12",
        "laravel/framework": "^12.37",
        "laravel/prompts": "^0.3.8",
        "nikic/php-parser": "^5.7",
        "phpstan/phpstan": "^2.1",
        "symfony/console": "^7.4",
        "aryeo/tooling-laravel": "0.0.33"
    },
    "require-dev": {
        "orchestra/testbench": "^10.6",
        "phpunit/phpunit": "^12.4.1",
        "nesbot/carbon": "^3.10",
        "orchestra/testbench-core": "^10.7",
        "pestphp/pest": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Support\\Entities\\": "src/Support/Entities",
            "Tooling\\Entities\\": "src/Tooling/Entities"
        },
        "exclude-from-classmap": [
            "*Test.php",
            "*TestCases.php",
            "/tests/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Justin Seliga",
            "email": "justinsel@zillowgroup.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "aryeo/tooling-laravel": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Support\\Entities\\Providers\\Provider"
            ]
        },
        "tooling": {
            "rector": {
                "configured_rules": "tooling/rector/configured-rules.php"
            },
            "phpstan": "tooling/phpstan/rules.neon"
        }
    }
}
